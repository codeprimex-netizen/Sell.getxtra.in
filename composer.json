{
    "name": "getxtra/sell",
    "description": "Sell.getxtra.in - Enterprise Digital Products Marketplace (Custom PHP)",
    "type": "project",
    "license": "proprietary",
    "require": {
        "php": ">=8.2",
        "ext-pdo": "*",
        "ext-json": "*",
        "ext-mbstring": "*"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5",
        "phpstan/phpstan": "^1.11",
        "squizlabs/php_codesniffer": "^3.10"
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        },
        "files": [
            "src/Support/helpers.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "migrate": "php bin/console migrate",
        "seed": "php bin/console seed",
        "serve": "php -S 127.0.0.1:8000 -t public",
        "test": "php bin/run-tests.php",
        "test:unit": "phpunit",
        "analyse": "phpstan analyse --no-progress",
        "lint": "phpcs",
        "lint:fix": "phpcbf",
        "syntax": "find src public bin database resources tests -name '*.php' -print0 | xargs -0 -n1 php -l > /dev/null",
        "ci": [
            "@syntax",
            "@lint",
            "@test"
        ]
    },
    "config": {
        "optimize-autoloader": true,
        "sort-packages": true
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
