# ─────────────────────────────────────────────────────────────
# Sell.getxtra.in — Environment Configuration (example)
# Copy to .env and fill in real values. NEVER commit .env.
# ─────────────────────────────────────────────────────────────

# Application
APP_NAME="Sell.getxtra.in"
APP_ENV=local                 # local | staging | production
APP_DEBUG=true
APP_URL=https://www.sell.getxtra.in
APP_KEY=                      # base64 32-byte key for encryption
APP_TIMEZONE=Asia/Kolkata

# Database — primary (read/write)
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=sell_getxtra
DB_USERNAME=sell
DB_PASSWORD=secret
DB_CHARSET=utf8mb4

# Database — read replica (optional; falls back to primary if unset)
DB_READ_HOST=
DB_READ_PORT=3306

# Redis (cache / session / queue / rate-limit)
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=

# Sessions
SESSION_DRIVER=redis          # redis | file
SESSION_LIFETIME=120          # minutes
SESSION_SECURE_COOKIE=true

# Queue
QUEUE_DRIVER=redis            # redis | database | sync

# Search
SEARCH_DRIVER=meilisearch     # meilisearch | opensearch | mysql
SEARCH_HOST=http://127.0.0.1:7700
SEARCH_KEY=

# Object storage (S3-compatible)
STORAGE_DRIVER=s3             # s3 | local
S3_ENDPOINT=
S3_REGION=ap-south-1
S3_BUCKET_PUBLIC=getxtra-public
S3_BUCKET_PRIVATE=getxtra-private
S3_KEY=
S3_SECRET=
CDN_URL=

# Mail
MAIL_DRIVER=smtp
MAIL_HOST=127.0.0.1
MAIL_PORT=1025
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM_ADDRESS=no-reply@sell.getxtra.in
MAIL_FROM_NAME="Sell.getxtra.in"

# Payment gateways
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
STRIPE_SECRET=
STRIPE_WEBHOOK_SECRET=

# Logging / observability
LOG_CHANNEL=json              # json | line
LOG_LEVEL=debug               # debug | info | warning | error
LOG_PATH=storage/logs/app.log

# Security
RATE_LIMIT_ENABLED=true
