# ─────────────────────────────────────────────────────────────
# Code.getxtra.in — Environment Configuration (example)
# Copy to .env and fill in real values. NEVER commit .env.
# In production, prefer a secrets manager/Vault (see SECRETS_* below).
# ─────────────────────────────────────────────────────────────

# ── Application ───────────────────────────────────────────────
APP_NAME="Code.getxtra.in"
APP_ENV=local                       # local | staging | production
APP_DEBUG=true
APP_URL=https://www.code.getxtra.in
APP_KEY=                            # base64: 32-byte key for encryption (php -r "echo 'base64:'.base64_encode(random_bytes(32));")
APP_TIMEZONE=Asia/Kolkata

# ── Localization (i18n) ───────────────────────────────────────
APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_SUPPORTED_LOCALES=en,hi         # comma-separated

# ── Database — primary (read/write) ───────────────────────────
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=code_getxtra
DB_USERNAME=sell
DB_PASSWORD=secret
DB_CHARSET=utf8mb4

# ── Database — read replica (optional; falls back to primary) ──
DB_READ_HOST=
DB_READ_PORT=3306

# ── Redis (cache / session / queue / rate-limit) ──────────────
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=

# ── Sessions ──────────────────────────────────────────────────
SESSION_DRIVER=cache                # cache (Redis, stateless) | file
SESSION_LIFETIME=120                # minutes
SESSION_SECURE_COOKIE=true

# ── Cache ─────────────────────────────────────────────────────
CACHE_DRIVER=redis                  # redis | file | array
CACHE_ENABLED=true
CACHE_PREFIX=gx:

# ── Queue ─────────────────────────────────────────────────────
QUEUE_DRIVER=database               # database | sync | (array in tests)
QUEUE_BACKLOG_THRESHOLD=1000        # alert threshold for queue depth

# ── Search ────────────────────────────────────────────────────
SEARCH_DRIVER=mysql                 # meilisearch | mysql (FULLTEXT fallback)
SEARCH_HOST=
SEARCH_KEY=

# ── Object storage (S3-compatible; local disk in dev) ─────────
STORAGE_DRIVER=s3                   # s3 | local
S3_ENDPOINT=
S3_REGION=ap-south-1
S3_BUCKET_PUBLIC=getxtra-public
S3_BUCKET_PRIVATE=getxtra-private
S3_KEY=
S3_SECRET=
CDN_URL=                            # e.g. https://cdn.code.getxtra.in
ASSET_MANIFEST=                     # optional path to a build manifest.json

# ── Commerce ──────────────────────────────────────────────────
COMMERCE_CURRENCY=INR
COMMERCE_COMMISSION_RATE=20         # % platform cut
COMMERCE_TAX_RATE=18                # % GST
COMMERCE_REFUND_WINDOW_DAYS=14
PAYMENT_DEFAULT_GATEWAY=offline     # offline | razorpay | stripe
PAYMENT_OFFLINE_SECRET=offline-dev-secret

# ── Payment gateways (leave blank to disable) ─────────────────
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
STRIPE_SECRET=
STRIPE_WEBHOOK_SECRET=

# ── Mail (dev logs to disk via LogMailer) ─────────────────────
MAIL_DRIVER=smtp                    # smtp | log (log writes to MAIL_LOG_PATH)
MAIL_HOST=127.0.0.1
MAIL_PORT=587
MAIL_ENCRYPTION=tls                 # tls (STARTTLS) | ssl | none
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM_ADDRESS=no-reply@code.getxtra.in
MAIL_FROM_NAME="Code.getxtra.in"
MAIL_LOG_PATH=storage/logs/mail.log

# ── Affiliate / referral program ──────────────────────────────
AFFILIATE_ENABLED=true
AFFILIATE_DEFAULT_RATE=10           # % of subtotal
AFFILIATE_MIN_PAYOUT=100

# ── Analytics ─────────────────────────────────────────────────
GA4_MEASUREMENT_ID=                 # optional; enabling requires CSP allowance

# ── Invoices ──────────────────────────────────────────────────
INVOICE_FORMAT=pdf                  # pdf | html

# ── Logging / observability ───────────────────────────────────
LOG_CHANNEL=json                    # json | line
LOG_LEVEL=info                      # debug | info | warning | error | critical
LOG_PATH=storage/logs/app.log
LOG_STREAM=false                    # true → write to stdout (containers)
TRACING_ENABLED=false               # W3C traceparent spans
METRICS_TOKEN=                      # bearer token to protect /metrics (optional)
METRICS_PATH=storage/metrics/metrics.json

# ── Security ──────────────────────────────────────────────────
RATE_LIMIT_ENABLED=true
GLOBAL_RATE_LIMIT=600               # requests/min/IP (defense-in-depth)

# ── Secrets provider (production: file/Vault) ─────────────────
SECRETS_DRIVER=env                  # env | file | chain
SECRETS_PATH=                       # JSON file for file/chain (Vault Agent / mounted secret)

# ── Privacy / compliance (GDPR / DPDP) ────────────────────────
PRIVACY_EXPORT_TTL_DAYS=7
PRIVACY_ERASURE_GRACE_DAYS=0
