{
  "title": "Code.getxtra.in — Service Overview (RED)",
  "uid": "sell-getxtra-red",
  "schemaVersion": 39,
  "tags": ["sell-getxtra", "red"],
  "timezone": "browser",
  "refresh": "30s",
  "templating": { "list": [] },
  "panels": [
    {
      "id": 1,
      "title": "Request rate (req/s)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        { "expr": "sum(rate(http_requests_total[5m]))", "legendFormat": "requests" }
      ]
    },
    {
      "id": 2,
      "title": "Error rate (5xx %)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [
        { "expr": "sum(rate(http_requests_errors_total[5m])) / sum(rate(http_requests_total[5m]))", "legendFormat": "error ratio" }
      ]
    },
    {
      "id": 3,
      "title": "Latency P50/P95/P99 (s)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "targets": [
        { "expr": "histogram_quantile(0.50, sum(rate(http_request_duration_seconds_bucket[5m])) by (le))", "legendFormat": "p50" },
        { "expr": "histogram_quantile(0.95, sum(rate(http_request_duration_seconds_bucket[5m])) by (le))", "legendFormat": "p95" },
        { "expr": "histogram_quantile(0.99, sum(rate(http_request_duration_seconds_bucket[5m])) by (le))", "legendFormat": "p99" }
      ]
    },
    {
      "id": 4,
      "title": "Queue jobs processed vs dead-lettered",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "targets": [
        { "expr": "sum(rate(jobs_processed_total[5m]))", "legendFormat": "processed" },
        { "expr": "sum(rate(jobs_dead_lettered_total[5m]))", "legendFormat": "dead-lettered" }
      ]
    },
    {
      "id": 5,
      "title": "Alerts fired",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "targets": [
        { "expr": "sum(increase(alerts_fired_total[15m])) by (alert, severity)", "legendFormat": "{{alert}} ({{severity}})" }
      ]
    }
  ]
}
