<?xml version="1.0"?>
<ruleset name="Code.getxtra.in">
    <description>Coding standard for Code.getxtra.in — PSR-12 with pragmatic exclusions (Req 23.1).</description>

    <!-- What to scan. -->
    <file>src</file>
    <file>bin</file>
    <file>public</file>

    <exclude-pattern>*/vendor/*</exclude-pattern>
    <exclude-pattern>*/storage/*</exclude-pattern>

    <!-- Show progress + sniff codes; use all cores. -->
    <arg value="ps"/>
    <arg name="colors"/>
    <arg name="parallel" value="4"/>
    <arg name="extensions" value="php"/>

    <rule ref="PSR12">
        <!-- Long SQL strings and fluent chains are readable beyond 120 cols. -->
        <exclude name="Generic.Files.LineLength"/>
    </rule>
</ruleset>
